# Required: session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI (docker): http://localhost:8081/api/auth/callback/google
# Authorized redirect URI (local dev): http://localhost:5173/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Local operations/demo mode. Set DEV_AUTH=0 to use real Google OAuth.
DEV_AUTH=1

# Source-only deployments can avoid MinIO by storing originals/results on disk.
# Docker deployments should leave this unset and use the default S3/MinIO path.
# STORAGE_DRIVER=local
# LOCAL_STORAGE_ROOT=./data/objects
# OFFICE_ENGINE=builtin

# Converter timeouts (defaults shown). SIDECAR_TIMEOUT_MS is the client-side
# abort for the LibreOffice sidecar; keep it above the sidecar's internal 120s
# soffice cap. BUILTIN_TIMEOUT_MS hard-kills a hung builtin (Chrome) conversion.
# SIDECAR_TIMEOUT_MS=150000
# BUILTIN_TIMEOUT_MS=120000

# The HWP precision engine (rhwp-python) ships inside the api/worker images at
# /opt/rhwp/bin/python3 (RHWP_PYTHON defaults to it via the Dockerfile), so no
# rhwp env is needed for Docker. Check GET /health/engines after boot.

# Optional commercial engines (free engines are used as fallback when unset).
# HANCOM_BASE_URL=
# HANCOM_API_KEY=
# ASPOSE_BASE_URL=
# ASPOSE_CLIENT_ID=
# ASPOSE_CLIENT_SECRET=
