# Standalone no-Docker runtime configuration.

NODE_ENV=production
PORT=18010
DATABASE_URL=file:/opt/mass-doc-to-pdf/data/app.db

# Store uploaded originals and converted PDFs on local disk instead of S3/MinIO.
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/opt/mass-doc-to-pdf/data/objects

# Default production renderer. This uses LibreOffice through the local sidecar
# and preserves Office/PPT layout far better than the source-only builtin path.
OFFICE_ENGINE=hwp-sidecar

# Set OFFICE_ENGINE=builtin only for emergency source/text extraction. In
# precise mode, builtin fallback is quality-gated and will not be exposed as a
# downloadable success for Office/PPT files.
HWP_SIDECAR_URL=http://127.0.0.1:18080

# Optional rhwp first-pass renderer. If unavailable or failing, HWP conversion
# falls back to H2Orestart and then the builtin converter while recording the
# attempt in /api/jobs/:id/quality.
RHWP_ENABLED=1
RHWP_PYTHON=python3
RHWP_TIMEOUT_MS=120000
RHWP_WORKER_SCRIPT=

# Required. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public origin used by Auth.js. Example: https://pdf.example.com
WEB_ORIGIN=http://localhost

# Keep DEV_AUTH=1 for private/internal operation without Google OAuth.
# Set DEV_AUTH=0 and fill Google credentials for real OAuth.
DEV_AUTH=1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional commercial engines. Leave blank to use LibreOffice/H2Orestart.
HANCOM_BASE_URL=
HANCOM_API_KEY=
ASPOSE_BASE_URL=
ASPOSE_CLIENT_ID=
ASPOSE_CLIENT_SECRET=

# Sidecar process config.
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=18080

# Conversion worker (durable queue). The worker process claims queued jobs so
# conversions survive API restarts and don't block the request thread.
WORKER_IDLE_POLL_MS=1000
WORKER_MAX_ATTEMPTS=3
WORKER_VISIBILITY_TIMEOUT_MS=300000
