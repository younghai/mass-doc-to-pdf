# Image prefix published by .github/workflows/publish-ghcr.yml.
# Example for https://github.com/younghai/mass-doc-to-pdf:
HWPTOPDF_IMAGE_PREFIX=ghcr.io/younghai/mass-doc-to-pdf
HWPTOPDF_IMAGE_TAG=latest

# Public service origin. Register this callback in Google Cloud:
# https://your-domain.example/api/auth/callback/google
WEB_ORIGIN=https://your-domain.example
WEB_PORT=8081

# Required secrets. Generate AUTH_SECRET with:
# openssl rand -base64 32
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production should use Google OAuth. Use DEV_AUTH=1 only for private demos.
DEV_AUTH=0

# MinIO credentials and bucket.
MINIO_ROOT_USER=hwptopdf
MINIO_ROOT_PASSWORD=
S3_BUCKET=hwptopdf

# Bind MinIO ports to localhost by default. Put MinIO behind a firewall or proxy
# before exposing these publicly.
MINIO_API_PORT=127.0.0.1:9000
MINIO_CONSOLE_PORT=127.0.0.1:9001

# Source-only deployments can avoid MinIO by storing originals/results on disk.
# Docker/image deployments should leave this unset and use the MinIO path above.
# STORAGE_DRIVER=local
# LOCAL_STORAGE_ROOT=/home/vts/hwptopdf/data/objects
# OFFICE_ENGINE=builtin

# Optional commercial engines. Leave blank to use Gotenberg/H2Orestart fallback.
HANCOM_BASE_URL=
HANCOM_API_KEY=
ASPOSE_BASE_URL=
ASPOSE_CLIENT_ID=
ASPOSE_CLIENT_SECRET=
